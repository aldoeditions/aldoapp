# Supabase — Aldo Éditions
# Copier en .env.local et renseigner les valeurs (depuis Supabase > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Clé service_role — usage serveur uniquement (scripts/seed). Ne jamais exposer côté client.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

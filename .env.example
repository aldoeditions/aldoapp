# ─────────────────────────────────────────────────────────────
# Aldo Éditions — variables d'environnement
# Copier ce fichier en `.env.local` et renseigner les valeurs.
# (récupérables dans Supabase → Project Settings → API)
# ⚠️ Ne jamais committer `.env.local` (il est git-ignored).
# ─────────────────────────────────────────────────────────────

# URL du projet Supabase (publique)
NEXT_PUBLIC_SUPABASE_URL=

# Clé anon publique Supabase (côté navigateur)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service_role Supabase — SECRÈTE, serveur uniquement.
# Utilisée pour l'upload Storage et l'invitation d'artistes.
# Ne JAMAIS l'exposer côté client ni la committer.
SUPABASE_SERVICE_ROLE_KEY=
